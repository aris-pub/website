<!-- Why Aris Exists -->
<section class="why-exists" id="why-exists">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Why Aris Exists</h2>
        </div>
        
        <div class="problem-solutions">
        <div class="problem-solution">
            <p class="problem">Publishers control your work, your timeline, your audience</p>
            <div class="arrow">→</div>
            <p class="solution">Your research, your terms. Publish when ready, keep full rights, reach readers via immediate feedback</p>
        </div>
        
        <div class="problem-solution">
            <p class="problem">Valuable review insights buried in email threads</p>
            <div class="arrow">→</div>
            <p class="solution">Reviews that build knowledge. Every comment preserved with context, threaded discussions that travel with papers, insights that compound over time</p>
        </div>
        
        <div class="problem-solution">
            <p class="problem">Readers can't see how conclusions were reached</p>
            <div class="arrow">→</div>
            <p class="solution">Complete transparency. Version history shows every change, interactive data reveals methodology, open research you can trust</p>
        </div>
    </div>
    </div>
</section>

